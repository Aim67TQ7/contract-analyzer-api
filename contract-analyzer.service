[Unit]
Description=Contract Analyzer API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/contract-analyzer
EnvironmentFile=/opt/contract-analyzer/.env
ExecStart=/opt/contract-analyzer/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8002
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
